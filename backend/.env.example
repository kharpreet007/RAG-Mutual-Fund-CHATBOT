# ==========================================
# Backend Configuration
# ==========================================

# Groq API Key for LLM answer generation (Required)
# Get a free key at https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Path to local ChromaDB vector store (Optional)
# Default is ./data/chroma
# CHROMA_PERSIST_DIRECTORY=./data/chroma

# FastAPI Server settings (Optional)
# HOST=0.0.0.0
# PORT=8000

# Embedding Model (Optional)
# Default is BAAI/bge-small-en-v1.5 (Runs locally, no API key needed)
# EMBEDDING_MODEL_NAME=BAAI/bge-small-en-v1.5
